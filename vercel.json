{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm ci",
  "functions": {
    "app/api/public/generate-demo/route.ts": {
      "maxDuration": 300
    },
    "app/api/upload/route.ts": {
      "maxDuration": 60
    },
    "app/api/upload-large/route.ts": {
      "maxDuration": 60
    },
    "app/api/ai-setup/generate-manual/route.ts": {
      "maxDuration": 300
    },
    "app/api/ai-setup/analyze-media/route.ts": {
      "maxDuration": 60
    },
    "app/api/properties/route.ts": {
      "maxDuration": 60
    },
    "app/api/properties/safe/route.ts": {
      "maxDuration": 60
    },
    "app/api/chatbot/route.ts": {
      "maxDuration": 60
    },
    "app/api/gestion/reservations/import-universal/route.ts": {
      "maxDuration": 60
    },
    "app/api/gestion/reservations/import-smart/route.ts": {
      "maxDuration": 60
    },
    "app/api/gestion/reservations/import-csv/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/guest-followup",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/demo-followup",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/check-trials",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/check-module-trials",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/email-sequence",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/chatbot-insights",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/health-check",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/onboarding",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron/send-reactivation-emails",
      "schedule": "0 10 * * *"
    }
  ],
  "headers": [
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}